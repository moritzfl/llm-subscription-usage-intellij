<idea-plugin>
    <id>de.moritzf.openai-usage-quota</id>
    <name>LLM Subscription Usage</name>
    <vendor>Moritzf</vendor>

    <description>
        Tracks LLM subscription usage quotas in the IDE status bar and popup, including OpenAI, Cursor, OpenCode Go, Ollama Cloud, Z.ai, MiniMax, and Kimi limits. Exposes quota data through IntelliJ MCP tools and can sync the currently running IntelliJ MCP server URL into JSON config files for local AI clients.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="openai-usage-quota-with-mcp.xml">com.intellij.mcpServer</depends>

    <resource-bundle>messages.OpenAiUsageQuotaBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="openai.usage.quota.settings"
                key="settings.displayName"
                bundle="messages.OpenAiUsageQuotaBundle"
                parentId="tools"
                instance="de.moritzf.quota.idea.settings.QuotaSettingsConfigurable"/>
        <postStartupActivity implementation="de.moritzf.quota.idea.mcp.McpServerUrlSyncStartupActivity"/>
        <postStartupActivity implementation="de.moritzf.quota.idea.openai.OpenAiProxyStartupActivity"/>
        <statusBarWidgetFactory implementation="de.moritzf.quota.idea.ui.toolbar.QuotaStatusBarWidgetFactory" id="openai.usage.quota.widget"/>
    </extensions>

    <actions>
        <action id="openai.usage.quota.mainToolbar"
                class="de.moritzf.quota.idea.ui.toolbar.QuotaMainToolbarAction">
            <add-to-group group-id="MainToolbarRight"/>
        </action>
    </actions>
</idea-plugin>
